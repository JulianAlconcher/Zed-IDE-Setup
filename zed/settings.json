{
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434"
    }
  },
  "proxy": "",
  "edit_predictions": {
    "ollama": {
      "api_url": "http://localhost:11434"
    },
    "provider": "copilot"
  },
  "icon_theme": "JetBrains New UI Icons (Dark)",
  "agent": {
    "default_model": {
      "provider": "zed.dev",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "medium"
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "session": {
    "trust_all_worktrees": true
  },
  "terminal": {
    "env": {},
    "font_size": 12.0,
    "font_family": "JetBrainsMono Nerd Font"
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "never"
  },
  "cursor_blink": true,
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New", "monospace"],
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "file_types": {
    "tailwindcss": ["*.css"],
    "csv (pipe)": ["*.csv"]
  },
  "linked_edits": true,
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "favorite_config_option_values": {
        "mode": ["auto"]
      },
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Vesper Blur"
  },
  "auto_install_extensions": {
    "catppuccin-icons": true,
    "charmed-icons": true,
    "csv": true,
    "dockerfile": true,
    "dracula": true,
    "git-firefly": true,
    "html": true,
    "jetbrains-new-ui-icons": true,
    "latex": true,
    "markdown-oxide": true,
    "mcp-server-supabase": true,
    "nvim-nightfox": true,
    "one-dark-pro": true,
    "snazzy": true,
    "sql": true,
    "the-dark-side": true,
    "tokyo-night": true,
    "vesper-blur": true,
    "vue": true
  }
}
